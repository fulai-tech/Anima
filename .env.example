# Required: LLM API Key (supports OpenAI-compatible APIs)
LLM_API_KEY=your-api-key-here

# Optional: LLM Model (default: gpt-4o)
LLM_MODEL=gpt-4o

# Optional: Custom API endpoint (for DeepSeek, Doubao, Ollama, etc.)
LLM_BASE_URL=

# Optional: MQTT Broker (default: localhost:1883)
MQTT_HOST=localhost
MQTT_PORT=1883

# Optional: Xiaomi Cloud credentials (for token acquisition)
XIAOMI_CLOUD_USER=
XIAOMI_CLOUD_PASS=
