# Required: LLM API Key (supports OpenAI-compatible APIs)
ANIMA_LLM_API_KEY=your-api-key-here

# Optional: LLM Model (default: gpt-4o)
ANIMA_LLM_MODEL=gpt-4o

# Optional: Custom API endpoint (for DeepSeek, Doubao, Ollama, etc.)
ANIMA_LLM_BASE_URL=

# Optional: Disable LLM deep thinking (required for Doubao)
ANIMA_LLM_DISABLE_THINKING=false

# Optional: MQTT Broker (default: localhost:1883)
ANIMA_MQTT_HOST=localhost
ANIMA_MQTT_PORT=1883

# Optional: Xiaomi Cloud credentials (for token acquisition)
ANIMA_XIAOMI_CLOUD_USER=
ANIMA_XIAOMI_CLOUD_PASS=
